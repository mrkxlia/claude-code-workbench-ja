{
  "properties": {
    "connectionReferences": {},
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "1.0.0.0",
      "parameters": {
        "wbja_AzureFoundryEndpoint (wbja_AzureFoundryEndpoint)": {
          "defaultValue": "",
          "type": "String",
          "metadata": {
            "schemaName": "wbja_AzureFoundryEndpoint",
            "description": "environmentvariable"
          }
        },
        "wbja_AzureFoundryApiKey (wbja_AzureFoundryApiKey)": {
          "defaultValue": "",
          "type": "String",
          "metadata": {
            "schemaName": "wbja_AzureFoundryApiKey",
            "description": "environmentvariable"
          }
        }
      },
      "triggers": {
        "manual": {
          "type": "Request",
          "kind": "PowerAppV2",
          "inputs": {
            "schema": {
              "type": "object",
              "properties": {
                "text": { "title": "prompt", "type": "string", "x-ms-dynamically-added": true },
                "text_1": { "title": "imageBase64", "type": "string", "x-ms-dynamically-added": true }
              },
              "required": ["text", "text_1"]
            }
          }
        }
      },
      "actions": {
        "HTTP_ChatCompletions_Vision": {
          "type": "Http",
          "inputs": {
            "method": "POST",
            "uri": "@{parameters('wbja_AzureFoundryEndpoint (wbja_AzureFoundryEndpoint)')}/openai/deployments/<deployment>/chat/completions?api-version=2024-10-21",
            "headers": {
              "Content-Type": "application/json",
              "api-key": "@parameters('wbja_AzureFoundryApiKey (wbja_AzureFoundryApiKey)')"
            },
            "body": {
              "messages": [
                { "role": "system", "content": "あなたは精密な OCR エンジンです。画像内の文字を改行・記号も含めて忠実に書き起こします。推測や補完はしないでください。" },
                {
                  "role": "user",
                  "content": [
                    { "type": "text", "text": "@{triggerBody()?['text']}" },
                    {
                      "type": "image_url",
                      "image_url": {
                        "url": "data:image/jpeg;base64,@{triggerBody()?['text_1']}",
                        "detail": "high"
                      }
                    }
                  ]
                }
              ],
              "max_tokens": 2000,
              "temperature": 0
            }
          },
          "runAfter": {},
          "runtimeConfiguration": {
            "secureData": { "properties": ["inputs", "outputs"] }
          }
        },
        "Respond_to_a_PowerApp_or_flow": {
          "type": "Response",
          "kind": "PowerApp",
          "inputs": {
            "statusCode": 200,
            "body": {
              "result": "@body('HTTP_ChatCompletions_Vision')?['choices'][0]?['message']?['content']"
            },
            "schema": {
              "type": "object",
              "properties": { "result": { "type": "string" } }
            }
          },
          "runAfter": { "HTTP_ChatCompletions_Vision": ["Succeeded"] }
        }
      },
      "outputs": {}
    }
  },
  "schemaVersion": "1.0.0.0"
}
