{
  "name": "11111111-1111-1111-1111-111111111111",
  "id": "/providers/Microsoft.Flow/flows/11111111-1111-1111-1111-111111111111",
  "type": "Microsoft.Flow/flows",
  "properties": {
    "apiId": "/providers/Microsoft.PowerApps/apis/shared_logicflows",
    "displayName": "Azure Foundry GPT - テキストのみ",
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "1.0.0.0",
      "parameters": {},
      "triggers": {
        "manual": {
          "type": "Request",
          "kind": "Button",
          "inputs": {
            "schema": {
              "type": "object",
              "properties": {
                "prompt": {
                  "type": "string",
                  "title": "prompt",
                  "x-ms-content-hint": "TEXT"
                }
              },
              "required": ["prompt"]
            }
          }
        }
      },
      "actions": {
        "HTTP_ChatCompletions": {
          "type": "Http",
          "inputs": {
            "method": "POST",
            "uri": "https://<resource>.openai.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2024-10-21",
            "headers": {
              "Content-Type": "application/json",
              "api-key": "<api-key>"
            },
            "body": {
              "messages": [
                { "role": "system", "content": "あなたは有能なアシスタントです。日本語で簡潔に回答してください。" },
                { "role": "user", "content": "@{triggerBody()?['prompt']}" }
              ],
              "max_tokens": 800,
              "temperature": 0.2
            }
          },
          "runAfter": {},
          "runtimeConfiguration": {
            "secureData": { "properties": ["inputs", "outputs"] }
          }
        },
        "Compose_Answer": {
          "type": "Compose",
          "inputs": "@body('HTTP_ChatCompletions')?['choices'][0]?['message']?['content']",
          "runAfter": { "HTTP_ChatCompletions": ["Succeeded"] }
        }
      },
      "outputs": {}
    },
    "connectionReferences": {}
  }
}
